// Prisma is the ORM for server-side (API) access to the database
//
// This file defines the schema for the database.
//  - make sure to run 'prisma generate' after making changes to this file
//  - make sure to run 'prisma db push' to sync the remote database with the schema
//
// Database is optional: when the environment variables are not set, the database is not used at all,
// and the storage of data in Big-AGI is limited to client-side (browser) storage.
//
// The database is used for:
//  - the 'sharing' function, to let users share the chats with each other
//  - user authentication and account management
//  - cloud backup of conversations
//  - multi-device synchronization

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL") // uses connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // uses a direct connection
}

//
// Storage of Linked Data
//
model LinkStorage {
  id String @id @default(uuid())

  ownerId    String
  visibility LinkStorageVisibility

  dataType  LinkStorageDataType
  dataTitle String?
  dataSize  Int
  data      Json

  upVotes    Int @default(0)
  downVotes  Int @default(0)
  flagsCount Int @default(0)
  readCount  Int @default(0)
  writeCount Int @default(1)

  // time-based expiration
  expiresAt DateTime?

  // manual deletion
  deletionKey String
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LinkStorageVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum LinkStorageDataType {
  CHAT_V1
}

//
// User Authentication & Management (NextAuth.js compatible)
//
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String? // For email+password auth (hashed with bcrypt)

  // Storage mode preference
  storageMode   UserStorageMode @default(LOCAL_ONLY)

  // User preferences
  isAdmin       Boolean   @default(false)

  // Enhanced role system for beta features
  role          UserRole  @default(USER)
  permissions   UserPermission[]

  // Master account flag (cannot be modified by other admins)
  isMasterDev   Boolean   @default(false)

  // Relations
  accounts      Account[]
  sessions      Session[]
  conversations DConversation[]
  settings      UserSettings?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// User roles for access control
enum UserRole {
  USER        // Regular beta tester - no beta features by default
  DEVELOPER   // Developer with specific feature access
  ADMIN       // Full admin access to all features
  MASTER      // Master developer - cannot be modified
}

// Feature-level permissions for beta access control
model UserPermission {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  feature   FeatureFlag
  granted   Boolean  @default(false)
  grantedBy String?  // User ID who granted this permission
  grantedAt DateTime @default(now())

  @@unique([userId, feature])
  @@index([userId])
}

// Beta features that require explicit permission
enum FeatureFlag {
  NEPHESH       // Autonomous Agents
  TRAIN         // Model Training
  FLOWCORE      // Workflow Builder
  ADMIN_PANEL   // Admin settings access
  ABOV3_MODELS  // Access to ABOV3 proprietary models (Genesis, Exodus, Solomon)
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

enum UserStorageMode {
  LOCAL_ONLY
  CLOUD_BACKUP
  CLOUD_FIRST
}

//
// User Conversations (Cloud Backup)
//
model DConversation {
  id String @id @default(uuid())

  // User ownership
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Conversation metadata
  userTitle  String?
  autoTitle  String?
  isArchived Boolean @default(false)
  userSymbol String?

  // Conversation data (stored as JSON for flexibility)
  messages Json // Array of DMessage objects

  // System purpose (deprecated but kept for compatibility)
  systemPurposeId String?

  // Sync metadata
  cloudBackupAt DateTime?

  // Timestamps
  created DateTime @default(now())
  updated DateTime @updatedAt

  @@index([userId])
  @@index([userId, updated])
  @@index([userId, isArchived])
}

//
// User Settings & Preferences
//
model UserSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // LLM configurations (stored as JSON)
  llmSettings Json? // DLLMId configs, model preferences, etc.

  // UI preferences
  uiSettings Json? // Theme, scaling, drawer states, etc.

  // App settings (folders, MCP servers, personas, tools, etc.)
  appSettings Json? // All other app-specific settings

  // Workflow data (training jobs, flowcore workflows)
  workflowData Json? // Training jobs, datasets, FlowCore workflows

  // Sync settings
  autoBackup      Boolean @default(false)
  backupFrequency Int?    // Minutes between auto-backups

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// Admin Settings (SMTP Configuration, etc.)
//
model AdminSettings {
  id String @id @default(cuid())

  // SMTP Configuration
  smtpHost     String?
  smtpPort     Int?
  smtpUser     String?
  smtpPassword String?
  smtpFrom     String?
  smtpSecure   Boolean @default(true)

  // Email templates
  emailTemplates Json? // Welcome email, verification email, etc.

  // General settings
  allowSignups             Boolean @default(true)
  requireEmailVerification Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// Invitation System (Invite-Only Access)
//
model InvitationCode {
  id          String           @id @default(cuid())
  code        String           @unique // 8 alphanumeric characters

  // Who created this invitation
  createdById String           // User ID of Master Developer

  // Optional: personalized invitation
  email       String?          // Pre-assigned email (optional)
  note        String?          // Internal note about this invitation

  // Usage tracking
  maxUses     Int              @default(1)  // How many times code can be used
  useCount    Int              @default(0)  // Current number of uses

  // Status
  status      InvitationStatus @default(ACTIVE)

  // Expiration (optional)
  expiresAt   DateTime?

  // Timestamps
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Relations
  usages      InvitationUsage[]

  @@index([code])
  @@index([status])
  @@index([createdById])
}

// Track each use of an invitation code
model InvitationUsage {
  id             String         @id @default(cuid())
  invitationId   String
  invitation     InvitationCode @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  // User who used the code
  userId         String         @unique // One user per usage
  userEmail      String         // Email at time of registration

  usedAt         DateTime       @default(now())

  @@index([invitationId])
  @@index([userId])
}

enum InvitationStatus {
  ACTIVE      // Can be used
  EXHAUSTED   // Max uses reached
  EXPIRED     // Past expiration date
  REVOKED     // Manually disabled
}

//
// Nephesh - Autonomous AI Agent System
//

// Autonomous AI agent profiles with independent configurations
model NepheshProfile {
  id              String   @id @default(uuid())
  userId          String
  name            String
  description     String?
  systemMessage   String   @db.Text // Core persona instructions

  // Execution configuration
  enabled         Boolean  @default(true)
  llmId           String   // User's configured DLLMId
  temperature     Float    @default(0.7)
  maxTokens       Int      @default(2048)

  // Skills & Tools
  enabledSkills   String[] // Skill IDs
  enabledTools    Json     // { fileOps: true, web: false, ... }

  // Memory configuration
  memoryEnabled   Boolean  @default(true)
  memoryMaxItems  Int      @default(1000)

  // Multi-channel bindings
  channelBindings Json     // { telegram: { chatId: "..." }, ... }

  // Subscription tier
  tier            SubscriptionTier @default(FREE)

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  jobs            NepheshJob[]
  memories        NepheshMemory[]
  channels        ChannelIntegration[]

  @@index([userId])
  @@index([userId, enabled])
}

// Background task execution with scheduling and monitoring
model NepheshJob {
  id              String   @id @default(uuid())
  profileId       String
  profile         NepheshProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  name            String
  type            JobType  // 'heartbeat' | 'scheduled' | 'triggered' | 'manual'
  schedule        String?  // Cron expression

  status          JobStatus // 'idle' | 'queued' | 'running' | 'completed' | 'error'
  progress        Int      @default(0)
  currentStep     String?

  inputPrompt     String?  @db.Text
  resultMessages  Json?    // DMessage[]

  heartbeatSkill  String?  // Skill ID for heartbeat tasks
  lastHeartbeat   DateTime?
  nextHeartbeat   DateTime?

  logs            Json     @default("[]")
  executionCount  Int      @default(0)
  totalTokens     Int      @default(0)

  error           String?  @db.Text
  retryCount      Int      @default(0)
  maxRetries      Int      @default(3)

  createdAt       DateTime @default(now())
  startedAt       DateTime?
  completedAt     DateTime?

  @@index([profileId])
  @@index([status])
  @@index([nextHeartbeat])
}

// Vector memory for persistent agent context (Phase 4)
model NepheshMemory {
  id              String   @id @default(uuid())
  profileId       String
  profile         NepheshProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  content         String   @db.Text
  summary         String?

  // Note: pgvector extension required for vector type
  // embedding       Unsupported("vector(1536)")?  // OpenAI dimensions

  source          String?  // 'conversation' | 'user_note'
  importance      Int      @default(5)  // 1-10 scale

  timestamp       DateTime @default(now())
  expiresAt       DateTime?
  lastAccessedAt  DateTime?

  conversationId  String?

  @@index([profileId])
  @@index([profileId, timestamp])
}

// Multi-channel integrations (Phase 5)
model ChannelIntegration {
  id              String   @id @default(uuid())
  profileId       String
  profile         NepheshProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  platform        ChannelPlatform // 'telegram' | 'whatsapp' | 'slack' | 'discord'

  config          Json     // Platform-specific settings
  accessToken     String?  @db.Text

  incomingWebhook String?
  enabled         Boolean  @default(true)

  @@unique([profileId, platform])
}

// Markdown-based skill definitions (Phase 2)
model NepheshSkill {
  id              String   @id @default(uuid())
  name            String   @unique
  version         String
  description     String?

  markdown        String   @db.Text  // Full skill content
  manifest        Json     // Parsed YAML frontmatter

  installedBy     String[] // User IDs
  permissions     String[] // ['file:read', 'web:fetch']
  requiredEnvVars String[]

  verified        Boolean  @default(false)
  installCount    Int      @default(0)

  @@index([name, version])
}

// Enums
enum SubscriptionTier {
  FREE        // 1 profile
  COMMERCIAL  // 10 profiles
  ENTERPRISE  // 50 profiles
}

enum JobType {
  HEARTBEAT   // Autonomous recurring task
  SCHEDULED   // Cron-based task
  TRIGGERED   // Event-based task
  MANUAL      // User-initiated task
}

enum JobStatus {
  IDLE        // Not yet started
  QUEUED      // In job queue
  RUNNING     // Currently executing
  COMPLETED   // Successfully finished
  ERROR       // Failed with error
}

enum ChannelPlatform {
  TELEGRAM
  WHATSAPP
  SLACK
  DISCORD
}

//
// Software Update System
//
model SoftwareUpdate {
  id          String       @id @default(cuid())
  version     String       // Semantic version from package.json in zip
  filename    String       // Original uploaded filename
  checksum    String       // SHA-256 hash of the zip file
  size        Int          // File size in bytes

  status      UpdateStatus @default(PENDING)
  uploadedBy  String       // User ID who uploaded
  appliedAt   DateTime?    // When update was successfully applied
  rollbackAt  DateTime?    // When update was rolled back
  error       String?      @db.Text // Error message if failed

  // Backup reference
  backupPath  String?      // Path to backup directory

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@index([createdAt])
}

enum UpdateStatus {
  PENDING      // Uploaded, awaiting validation
  VALIDATING   // Checking zip structure and checksum
  BACKING_UP   // Creating backup of current files
  APPLYING     // Extracting and replacing files
  MIGRATING    // Running database migrations
  RESTARTING   // Signaling app restart
  COMPLETED    // Successfully applied
  FAILED       // Failed during any stage
  ROLLED_BACK  // Reverted to previous version
}
