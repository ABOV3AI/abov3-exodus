# =============================================================================
# ABOV3 Exodus - Production Environment Variables
# =============================================================================
# Copy this file to .env.production and fill in your values.
# NEVER commit .env.production to version control!
# =============================================================================

# =============================================================================
# REQUIRED - Authentication
# =============================================================================

# JWT signing secret - CRITICAL for security
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Public URL of your deployment (no trailing slash)
NEXTAUTH_URL=https://your-domain.com

# =============================================================================
# REQUIRED - Database
# =============================================================================

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://abov3_exodus:your-password@localhost:5432/abov3_exodus?schema=public

# =============================================================================
# REQUIRED - API Security
# =============================================================================

# Eden Training API authentication key
# Required if using Eden MCP server for model training
# Generate with: openssl rand -hex 32
EDEN_API_KEY=

# FlowCore webhook authentication secret
# Required if external systems trigger workflow webhooks
# Generate with: openssl rand -hex 32
FLOWCORE_WEBHOOK_SECRET=

# =============================================================================
# OPTIONAL - Email (Magic Link Authentication)
# =============================================================================

# SMTP server configuration
# EMAIL_SERVER_HOST=smtp.example.com
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER=your-smtp-user
# EMAIL_SERVER_PASSWORD=your-smtp-password
# EMAIL_FROM=noreply@your-domain.com

# =============================================================================
# OPTIONAL - Analytics
# =============================================================================

# PostHog for error tracking and analytics
# POSTHOG_API_KEY=
# POSTHOG_ENV_ID=

# =============================================================================
# OPTIONAL - AI Provider API Keys (Server-Side)
# =============================================================================
# These are shared across all users. Users can also add their own keys.

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Google AI
# GOOGLE_AI_API_KEY=

# Mistral
# MISTRAL_API_KEY=

# Groq
# GROQ_API_KEY=

# =============================================================================
# BUILD OPTIONS
# =============================================================================

# Set to 'standalone' for Docker optimized builds
BIG_AGI_BUILD=standalone

# Node.js production mode
NODE_ENV=production
